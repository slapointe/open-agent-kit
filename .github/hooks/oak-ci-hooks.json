{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "oak-dev ci hook sessionStart --agent copilot",
        "powershell": "oak-dev ci hook sessionStart --agent copilot",
        "timeoutSec": 60
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "oak-dev ci hook sessionEnd --agent copilot",
        "powershell": "oak-dev ci hook sessionEnd --agent copilot",
        "timeoutSec": 60
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "oak-dev ci hook userPromptSubmitted --agent copilot",
        "powershell": "oak-dev ci hook userPromptSubmitted --agent copilot",
        "timeoutSec": 60
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "oak-dev ci hook postToolUse --agent copilot",
        "powershell": "oak-dev ci hook postToolUse --agent copilot",
        "timeoutSec": 60
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "oak-dev ci hook errorOccurred --agent copilot",
        "powershell": "oak-dev ci hook errorOccurred --agent copilot",
        "timeoutSec": 60,
        "comment": "Maps to post-tool-use-failure endpoint"
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "oak-dev ci hook SessionStart --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "oak-dev ci hook UserPromptSubmit --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "oak-dev ci hook PreToolUse --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "oak-dev ci hook PostToolUse --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "oak-dev ci hook PreCompact --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "oak-dev ci hook SubagentStart --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "oak-dev ci hook SubagentStop --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "oak-dev ci hook Stop --agent vscode-copilot 2>/dev/null || true",
        "timeout": 60
      }
    ]
  }
}