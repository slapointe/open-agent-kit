{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "oak *": "allow",
      "oak-dev *": "allow"
    }
  },
  "mcp": {
    "oak-ci": {
      "type": "local",
      "command": [
        "oak-dev",
        "team",
        "mcp"
      ]
    },
    "oak-swarm": {
      "type": "local",
      "command": [
        "oak-dev",
        "swarm",
        "mcp"
      ]
    }
  }
}